# ═══════════════════════════════════════════════════════
# Hopkinson-Web 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# LLM 大模型 API 配置
# 支持的提供商: zhipu | moonshot | deepseek | openai
VITE_LLM_PROVIDER=deepseek

# API 密钥 (从对应平台获取)
# 智谱AI: https://open.bigmodel.cn/
# Moonshot: https://platform.moonshot.cn/
# DeepSeek: https://platform.deepseek.com/
# OpenAI: https://platform.openai.com/
VITE_LLM_API_KEY=sk-fb530a031e5d4dcbbe3894fce7f74436

# 模型名称 (可选，不填则使用默认值)
# 智谱: glm-4-flash (免费) / glm-4-plus
# Moonshot: moonshot-v1-8k / moonshot-v1-32k
# DeepSeek: deepseek-chat
# OpenAI: gpt-4o-mini / gpt-4o
VITE_LLM_MODEL=deepseek-chat

# 自定义 API 地址 (可选，用于代理或私有部署)
VITE_LLM_BASE_URL=

# ═══════════════════════════════════════════════════════
# 火山引擎 TTS 配置
# 申请地址: https://console.volcengine.com → 语音技术 → 语音合成
# 不配置则自动降级为 Web Speech API
# ═══════════════════════════════════════════════════════
VITE_VOLCANO_APP_ID=your_app_id_here
VITE_VOLCANO_ACCESS_TOKEN=your_access_token_here

# 音色选择: BV700_V2=灿灿(活泼女声), BV406=梓梓(温柔女声), BV001=通用女声
# https://console.volcengine.com/speech/service/10007
VITE_VOLCANO_VOICE_TYPE=zh_male_jieshuoxiaoming_moon_bigtts

# 集群: volcano_mega_tts (大模型语音合成)
VITE_VOLCANO_CLUSTER=volcano_mega_tts

# ═══════════════════════════════════════════════════════
# 后端服务连接 (Phase 3)
# 本地开发: http://localhost:8000
# 启动后端: cd hopkinson-backend && uvicorn main:app --reload
# ═══════════════════════════════════════════════════════
VITE_BACKEND_URL=http://localhost:8000
