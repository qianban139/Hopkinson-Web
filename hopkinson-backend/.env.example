# Hopkinson Backend 环境变量模板
# 复制为 .env 并填入实际值。生产环境密钥必须使用强随机值生成:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# ─── 运行环境 ───
# development / production
APP_ENV=development

# ─── 数据库 ───
# 本地开发 SQLite
DATABASE_URL=sqlite+aiosqlite:///./hopkinson.db
# 生产 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://hopkinson_user:YOUR_PASSWORD@localhost:5432/hopkinson

# ─── 安全密钥 (必须,>=32 字符,必须随机) ───
JWT_SECRET=REPLACE_WITH_RANDOM_48_CHARS
SESSION_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_48_CHARS

# ─── 初始管理员密码 ───
# 种子脚本 db.seed 使用,创建后立即改密
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── CORS ───
# 开发
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产(必须是具体域名,禁止 *,逗号分隔)
# 国内直连 ECS 的 origin(IP+端口)必须也加,例如 http://47.114.88.130:8080
# CORS_ORIGINS=https://www.hopkinson-lab.com,https://api.hopkinson-lab.com,http://47.114.88.130:8080

# ─── 调试 ───
DB_ECHO=false
